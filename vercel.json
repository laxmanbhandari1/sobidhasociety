{
    "routes": [
      {
        "src": "/css/(.*)",
        "dest": "/frontend/css/$1"
      },
      {
        "src": "/js/(.*)",
        "dest": "/frontend/js/$1"
      },
      {
        "src": "/images/(.*)",
        "dest": "/frontend/assets/$1"
      },
      {
        "src": "/",
        "dest": "/frontend/pages/index.html"
      }
    ]
  }